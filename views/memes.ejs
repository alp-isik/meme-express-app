<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Memes - Meme Central</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/navbar.css" />
  </head>

  <body>
    <%- include("./partials/navbar.ejs") %>
    <br />
    <main class="container mt-5 pt-2">
      <form class="d-flex gap-1 mb-2" method="GET" action="/memes">
        <input
          class="form-control"
          type="text"
          name="search"
          placeholder="Search meme name..."
          value="<%= search || '' %>"
        />
        <button class="btn btn-primary" type="submit">Search</button>
        <a class="btn btn-secondary" href="/memes">Clear</a>
      </form>
      <%- include("./partials/memes.ejs") %>
    </main>
    <%- include("./partials/scripts.ejs") %>
  </body>
</html>
